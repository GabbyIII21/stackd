# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# ─── Contract scripts (Foundry, Base Mainnet) ────────────────────────────────
# Deployer key for script/Deploy.s.sol. NOTE: the script reads PRIVATE_KEY
# (vm.envUint), so deploy with:
#   PRIVATE_KEY=$DEPLOYER_PRIVATE_KEY forge script script/Deploy.s.sol:Deploy \
#     --rpc-url https://mainnet.base.org --broadcast
DEPLOYER_PRIVATE_KEY=

# ─── Frontend ────────────────────────────────────────────────────────────────
# StackdRegistry on Base Mainnet (chain 8453). Optional — matches the committed
# default in src/lib/contract.ts. Same address on Base Sepolia (nonce-0 deploy).
VITE_STACKD_REGISTRY_ADDRESS=0x27A114c7C0e0d0ef97538407C447D7601c940d4D

# REQUIRED for logging (pins the image + log JSON to IPFS). Reads — leaderboard,
# profile, explore, connecting a wallet — all work WITHOUT this. Only "Log Today"
# and "Activate Freeze" need a working pin.
# Get one at https://app.pinata.cloud  ->  API Keys  ->  New Key
# (enable pinFileToIPFS + pinJSONToIPFS), then paste the JWT below.
PINATA_JWT=

# ─── Base Builder Codes (ERC-8021 attribution) ───────────────────────────────
# Builder Code from base.dev > Settings > Builder Codes. The frontend appends an
# ERC-8021 dataSuffix to txns for attribution + referral fees (see the
# `adding-builder-codes` skill / `ox/erc8021`). Paste the code when issued, then
# wire it into the wagmi client's `dataSuffix`. Empty = no attribution (safe).
VITE_BUILDER_CODE=
